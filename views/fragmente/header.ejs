<header style="position: relative;">

    <h1 class="oswald">Zona Echo<i class="fa-solid fa-music fa-bounce"></i></h1>

    <div class="form-check form-switch"
        style="position: absolute; top: 1rem; right: 1rem; z-index: 2000; display: flex; align-items: center;">
        <input class="form-check-input" type="checkbox" role="switch" id="themeSwitch"
            style="cursor:pointer; margin-right: 0.5rem;">
        <label class="form-check-label text-white" for="themeSwitch" style="cursor:pointer">
            <i id="themeIcon" class="fa-solid fa-sun" style="font-size: 1.25rem;"></i>
        </label>
    </div>

    <nav>
        <!-- <label id="hamburger" for="ch-menu">
                <img src="resurse/imagini/Hamburger_icon_alb.png" alt="menu">
            </label> -->
        <label for="ch-menu" id="hamburger">
            <span></span>
            <span></span>
            <span></span>
        </label>
        <input type="checkbox" id="ch-menu" />
        <ul class="meniu">
            <li>
                <div class="wrapper-buton">
                    <div class="strat-text">
                        <a href="/">
                            <div class="text-de-comprimat"><i class="fa-solid fa-house"></i><span class="text-home">
                                    Acasa</span></div>
                        </a>
                    </div>
                    <div class="strat-umbra">
                        <a href="/">
                            <i class="fa-solid fa-house"></i><span class="text-home"> Acasa</span>
                        </a>
                    </div>
                </div>
            </li>
            <li>
                <div class="text-de-comprimat">
                    <div class="text-icon"><i class="fa-solid fa-headphones"></i></div> Produse
                </div>
                <ul>
                    <li>
                        <div class="wrapper-buton">
                            <div class="strat-text"><a href="/produse">Toate produsele</a></div>
                        </div>
                    </li>
                    <% if (locals.optiunimeniu && locals.optiunimeniu.length > 0) { %>
                        <% locals.optiunimeniu.forEach(function(opt) { %>
                            <li>
                                <div class="wrapper-buton">
                                    <div class="strat-text"><a href="/produse?tip=<%= encodeURIComponent(opt.unnest) %>"><%= opt.unnest %></a></div>
                                </div>
                            </li>
                        <% }); %>
                    <% } %>
                </ul>
            </li>
            <li>
                <div class="text-de-comprimat">
                    <div class="text-icon"><i class="fa-solid fa-graduation-cap"></i></div> Învață
                </div>
                <ul>
                    <li>
                        <div class="wrapper-buton">
                            <div class="strat-text"><a href="/index#dictionar">Termeni tehnici</a></div>
                        </div>
                    </li>
                    <li>
                        <div class="wrapper-buton">
                            <div class="strat-text"><a href="/index#informative-videos">Videoclipuri</a></div>
                        </div>
                    </li>
                    <li>
                        <div class="wrapper-buton">
                            <div class="strat-text"><a href="/index#index-intrebari">Întrebări frecvente</a></div>
                        </div>
                    </li>
                </ul>
            </li>
            <li>
                <div class="text-de-comprimat">
                    <div class="text-icon"><i class="fa-solid fa-users"></i></div> Despre noi
                </div>
                <ul>
                    <li>
                        <div class="wrapper-buton">
                            <div class="strat-text"><a href="/index#orar">Program</a></div>
                        </div>
                    </li>
                    <li>
                        <div class="wrapper-buton">
                            <div class="strat-text"><a href="/index#anunturi">Anunturi</a></div>
                        </div>
                    </li>
                    <li>
                        <div class="wrapper-buton">
                            <div class="strat-text"><a href="/index#despre-brand">Istoricul companiei</a></div>
                        </div>
                    </li>
                </ul>
            </li>
        </ul>
    </nav>
</header>